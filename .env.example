# Copie este arquivo para .env e preencha com suas credenciais

# Exchange API (Opcional - apenas para trading real)
EXCHANGE=binance
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Telegram Bot (Obrigatório para o bot)
# Obtenha o token com @BotFather no Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Seu Chat ID para receber alertas
# Obtenha com @userinfobot no Telegram
TELEGRAM_CHAT_ID=123456789

# Perfis separados (recomendado para rodar MAIN e OTC em paralelo)
# BOT_PROFILE pode ser: main | otc
# BOT_INSTANCE_NAME evita conflito de lock entre instâncias
BOT_PROFILE=main
BOT_INSTANCE_NAME=main

# Token/chat dedicados por perfil (têm prioridade sobre as chaves globais)
TELEGRAM_BOT_TOKEN_MAIN=123456789:MAIN_token
TELEGRAM_CHAT_ID_MAIN=123456789

TELEGRAM_BOT_TOKEN_OTC=123456789:OTC_token
TELEGRAM_CHAT_ID_OTC=987654321
